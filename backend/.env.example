# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_RAG=rag_documents
QDRANT_COLLECTION_MEM0=mem0_memories

# mem0
MEM0_USER_COLLECTION=mem0_memories

# App
APP_NAME=MemRAG Chatbot
APP_VERSION=0.1.0
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Storage backend: local | s3
STORAGE_BACKEND=local

# S3 config (fill in when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Bắt buộc nếu dùng temporary credentials (key bắt đầu bằng ASIA... từ STS/SSO)
S3_SESSION_TOKEN=
S3_ENDPOINT_URL=
S3_PREFIX=uploads
S3_PRESIGNED_URL_EXPIRY=3600

# Context filter
MAX_CONTEXT_MESSAGES=20
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
